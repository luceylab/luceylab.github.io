#df <- read.csv(file = "coral_main.csv")
df <- read.csv(file = "Pcrit_summary.csv")
str(df)
##
p1 <- ggplot(df, aes(x = temperature, y = midpoint, color =spp)) +
geom_smooth(method = loess, se = TRUE) +
geom_point(size = 1) +
#scale_color_manual(values=species_col) +
theme_minimal(base_size = 10) +
facet_grid(. ~ spp)
p1
p1b <- ggplot(df, aes(x = temperature, y = midpoint, group = temperature, color =spp)) +
geom_boxplot() +
geom_jitter(size=1.5, pch=1) +
#scale_color_manual(values=species_col) +
theme_bw(base_size = 12) +
facet_grid(. ~ spp)
p1b
# summarize data in new dataframe
df_sum <- df %>%
group_by(spp) %>%
summarise(
x = mean(midpoint),
sd = sd(midpoint),
n = n(),
se = sd / sqrt(n)
)
df_sum
?summarise
library(tidyverse)
# summarize data in new dataframe
df_sum <- df %>%
group_by(spp) %>%
summarise(
x = mean(midpoint),
