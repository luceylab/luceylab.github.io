?conv_o2
df$Pcrit_mgL <- conv_o2(o2 = df$midpoint, from = "hPa", to = "mg_per_l",
temp = df$temperature,
atm_pres = 1013.25)
# summarize data in new dataframe
df_sum <- df %>%
group_by(spp) %>%
summarise(
x = mean(Pcrit_mgL),
sd = sd(Pcrit_mgL),
n = n(),
se = sd / sqrt(n)
)
df_sum
p <- ggplot(df_sum, aes(x=factor(spp), y=x)) +
geom_bar() +
geom_errorbar(aes(ymax=x+se, ymin=x-se),position=position_jitter(h=0.01, w=.01), width=.1)+
labs(x = "spp",
y = "Pcrit") +
theme_bw(base_size = 12) +
theme(legend.position="none")
p
p <- ggplot(df_sum, aes(x=factor(spp), y=x)) +
geom_bar(stat = "identity")+
geom_errorbar(aes(ymax=x+se, ymin=x-se),position=position_jitter(h=0.01, w=.01), width=.1)+
labs(x = "spp",
y = "Pcrit") +
theme_bw(base_size = 12) +
theme(legend.position="none")
p
