#df <- read.csv(file = "coral_main.csv")
df <- read.csv(file = "Pcrit_summary.csv")
str(df)
df$Pcrit_kPa <- conv_o2(o2 = df$midpoint, from = "hPa", to = "kPa",
temp = df$temperature,
atm_pres = 1013.25)
df$Pcrit_mgL <- conv_o2(o2 = df$midpoint, from = "hPa", to = "mg_per_l",
temp = df$temperature,
atm_pres = 1013.25)
df <- df[which(df$spp == 'ssid'),]
df_sum <- df %>%
group_by(spp, temperature) %>%
summarise(
x = mean(Pcrit_kPa),
sd = sd(Pcrit_kPa),
n = n(),
se = sd / sqrt(n)
)
df_sum
df_sum <- df %>%
group_by(spp, temperature) %>%
summarise(
x = mean(Pcrit_mgL),
sd = sd(Pcrit_mgL),
n = n(),
se = sd / sqrt(n)
)
df_sum
temp <- ggplot(df_sum, aes(x=factor(temperature), y=x, color=spp, group=spp)) +
geom_line(aes(linetype=spp), size=.6) +
#geom_bar(stat = "identity")+
geom_point(size=.5) +
geom_errorbar(aes(ymax=x+se, ymin=x-se),position=position_jitter(h=0.01, w=.01), width=.1)+
labs(y = "Pcrit (kPa)",
x = "temp. (C)") +
theme_bw(base_size = 12) +
theme(legend.position="bottom")
temp +  facet_grid(. ~ spp)
p <- ggplot(df_sum, aes(x=factor(spp), y=x,)) +
geom_bar(stat = "identity")+
